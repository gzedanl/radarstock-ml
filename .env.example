# URL del frontend en Vercel, para CORS. Sin esto, CORS no permite ningún origen.
FRONTEND_URL=https://radarstock.vercel.app

# Token compartido con el frontend Next.js (mismo valor en
# INTERNAL_SERVICE_TOKEN de radarstock/.env.local). Protege /predict y
# /internal/check-alerts.
INTERNAL_SERVICE_TOKEN=

# Fase 3.4 — APIs externas: todas son públicas y no requieren API key
# (mindicador.cl, apis.digital.gob.cl, Open-Meteo, Yahoo Finance chart API).
# No hay variables adicionales que configurar acá.

# Fase 3.5 — Supabase: lectura de products/predictions para
# /internal/check-alerts, y desde el worker (worker.py) para guardar el
# resultado de cada predicción encolada. Usa la service role key, igual
# que el webhook de Mercado Pago del frontend — nunca la expongas al cliente.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Escalabilidad — cola de predicciones (opcional). Sin esto, /predict
# calcula síncrono como antes (útil para desarrollo local sin Redis). Con
# esto configurado, /predict encola el job y responde 202 de inmediato;
# hace falta correr `python worker.py` en un proceso aparte para que algo
# consuma la cola (en Render: un Background Worker service separado,
# mismo repo, mismo Dockerfile, start command `python worker.py`).
REDIS_URL=
