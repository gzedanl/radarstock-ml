# URL del frontend en Vercel, para CORS. Sin esto, CORS no permite ningún origen.
FRONTEND_URL=https://radarstock.vercel.app

# Token compartido con el frontend Next.js (mismo valor en
# INTERNAL_SERVICE_TOKEN de radarstock/.env.local). Protege /predict y
# /internal/check-alerts.
INTERNAL_SERVICE_TOKEN=

# Fase 3.4 — APIs externas: todas son públicas y no requieren API key
# (mindicador.cl, apis.digital.gob.cl, Open-Meteo, Yahoo Finance chart API).
# No hay variables adicionales que configurar acá.

# Fase 3.5 — Supabase (solo lectura de products/predictions para
# /internal/check-alerts). Usa la service role key, igual que el
# webhook de Mercado Pago del frontend — nunca la expongas al cliente.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
